# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Claude API (used server-side / edge function)
ANTHROPIC_API_KEY=your-claude-api-key

# Figma OAuth (register at https://www.figma.com/developers/apps)
VITE_FIGMA_CLIENT_ID=your-figma-client-id
FIGMA_CLIENT_ID=your-figma-client-id
FIGMA_CLIENT_SECRET=your-figma-client-secret

# shadcn Studio Pro (do not commit real values)
EMAIL=your-email@example.com
LICENSE_KEY=your-license-key

# ----- Vercel Deployment Notes -----
# All VITE_* variables must be added in the Vercel dashboard under
# Project Settings > Environment Variables for production/preview/development.
# Server-only variables (ANTHROPIC_API_KEY, FIGMA_CLIENT_SECRET) should NOT
# be prefixed with VITE_ to avoid exposing them to the client bundle.
# OAuth callback URLs must be updated to the production domain in:
#   - Supabase Auth > URL Configuration > Redirect URLs
#   - Figma Developer App > Callback URL
